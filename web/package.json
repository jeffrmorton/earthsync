    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.183.0",
    "@tailwindcss/vite": "^4.2.0",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^26.0.0",
