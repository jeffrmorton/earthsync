{
    "name": "earthsync",
    "version": "1.1.29",
    "private": true,
    "description": "Dockerized platform for simulating, ingesting, processing, and visualizing Schumann Resonance data",
    "workspaces": [
        "backend",
        "frontend",
        "detectors"
    ],
    "scripts": {
        "lint": "npm run lint --workspaces --if-present",
        "lint:backend": "npm run lint --workspace=backend",
        "lint:frontend": "npm run lint --workspace=frontend",
        "lint:detectors": "npm run lint --workspace=detectors",
        "format": "npm run format --workspaces --if-present",
        "format:check": "npm run format:check --workspaces --if-present",
        "test": "npm run test:unit --workspaces --if-present",
        "test:backend": "npm run test:unit --workspace=backend",
        "test:frontend": "npm run test --workspace=frontend",
        "test:integration": "docker compose exec -T backend sh -c 'NODE_ENV=test npx jest integration.test.js --verbose --detectOpenHandles --forceExit'"
    },
    "license": "MIT"
}